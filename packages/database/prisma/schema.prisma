// Internshala clone — Prisma schema (MVP for 2-day build)
// Auth: NextAuth v4 (Google OAuth, JWT strategy — no DB sessions)
// Storage: MinIO (S3-compatible) for resumes and logos

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String  @id @default(cuid())
  name  String?
  email String? @unique
  phone String? @unique
  image String?

  supabaseUserId String? @unique @db.Uuid

  googleId String? @unique

  role          UserRole @default(STUDENT)
  roleConfirmed Boolean  @default(false)
  isBanned      Boolean  @default(false)

  isPremium    Boolean   @default(false)
  premiumSince DateTime?

  isOnline   Boolean   @default(false)
  lastSeenAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentProfile     StudentProfile?
  employerProfile    EmployerProfile?
  companyMemberships CompanyMember[]
  listingsPosted     Listing[]        @relation("ListingPostedBy")
  listingsTakenDown  Listing[]        @relation("ListingTakenDownBy")
  applications       Application[]
  savedListings      SavedListing[]
  assets             Asset[]
  notifications      Notification[]
  payments           Payment[]
  messagesSent       Message[]        @relation("MessageSentBy")
  conversationReads  ConversationRead[]

  studentConversations   Conversation[] @relation("StudentConversations")
  recruiterConversations Conversation[] @relation("RecruiterConversations")
}

model StudentProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String?
  phone     String?
  city      String?
  dob       DateTime?
  gender    Gender?
  bio       String?  @db.Text

  resumeUrl String? // pointer to latest resume Asset.url

  educations     Education[]
  experiences    WorkExperience[]
  projects       Project[]
  skills         StudentSkill[]
  certifications Certification[]
  languages      Language[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
}

model Education {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  institute    String
  degree       String
  fieldOfStudy String?
  startYear    Int
  endYear      Int?
  grade        String?
  current      Boolean @default(false)

  @@index([studentId])
}

model WorkExperience {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  company     String
  title       String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  current     Boolean   @default(false)
  description String?   @db.Text

  @@index([studentId])
}

model Project {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  title       String
  link        String?
  description String?   @db.Text
  startDate   DateTime?
  endDate     DateTime?

  @@index([studentId])
}

model Skill {
  id   String @id @default(cuid())
  name String @unique // normalised, lowercase

  students      StudentSkill[]
  listingSkills ListingSkill[]
}

model StudentSkill {
  studentId String
  skillId   String
  level     Int? // 1..5

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  skill   Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([studentId, skillId])
  @@index([skillId])
}

model Certification {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  name          String
  issuer        String?
  issueDate     DateTime?
  credentialUrl String?

  @@index([studentId])
}

model Language {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  name        String
  proficiency Int? // 1..5

  @@index([studentId])
}

model EmployerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String?
  phone     String?
  jobTitle  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  logoUrl     String?
  website     String?
  linkedinUrl String?
  about       String? @db.Text
  industry    String?
  size        String?
  city        String?
  foundingYear Int?

  // Admin verification gate. A company starts PENDING and cannot post
  // listings until APPROVED. REJECTED carries a rejectionNote and can be
  // edited+resubmitted (which flips status back to PENDING).
  verificationStatus CompanyVerificationStatus @default(PENDING)
  rejectionNote      String?                   @db.Text
  submittedAt        DateTime?
  approvedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  CompanyMember[]
  listings Listing[]

  @@index([verificationStatus, submittedAt])
}

model CompanyMember {
  companyId String
  userId    String
  role      CompanyRole @default(MEMBER)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@id([companyId, userId])
  @@index([userId])
}

model Listing {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  postedById String
  postedBy   User   @relation("ListingPostedBy", fields: [postedById], references: [id], onDelete: Cascade)

  type        ListingType
  title       String
  mode        WorkMode
  city        String?
  description String      @db.Text

  responsibilities String[]
  perks            String[]
  preferences      String[]
  skillTagsRaw     String[] // free-text snapshot; normalised m2m below

  stipendMin     Int?
  stipendMax     Int?
  currency       String?   @default("INR")
  durationMonths Int?
  startDate      DateTime?
  applyBy        DateTime?
  openings       Int?      @default(1)
  partTime       Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime? // null = live, non-null = closed

  // Lifecycle. expiresAt is set on creation to createdAt + 30 days; once it
  // passes the listing is hidden from public surfaces until the founder
  // renews. pausedAt = "Not Hiring" — also hides from browse but keeps
  // existing applicants visible to the founder.
  expiresAt DateTime?
  pausedAt  DateTime?

  // Admin moderation (soft-removal). When takenDownAt is set the listing
  // becomes hidden from public browse + the founder's own listings show it
  // as "Removed by admin" with the reason. An admin can restore it.
  takenDownAt     DateTime?
  takedownReason  String?  @db.Text
  takenDownById   String?
  takenDownBy     User?    @relation("ListingTakenDownBy", fields: [takenDownById], references: [id], onDelete: SetNull)

  skills       ListingSkill[]
  applications Application[]
  savedBy      SavedListing[]

  @@index([type, createdAt])
  @@index([companyId])
  @@index([postedById])
  @@index([city])
  @@index([applyBy])
  @@index([closedAt])
  @@index([takenDownAt])
  @@index([expiresAt])
  @@index([pausedAt])
}

model ListingSkill {
  listingId String
  skillId   String

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([listingId, skillId])
  @@index([skillId])
}

model Application {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  status      ApplicationStatus @default(APPLIED)
  coverLetter String?           @db.Text
  resumeUrl   String? // snapshot of resume at time of apply

  appliedAt       DateTime @default(now())
  statusUpdatedAt DateTime @default(now())

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@unique([listingId, studentId])
  @@index([studentId, status])
  @@index([listingId, status])
  @@index([conversationId])
}

model Conversation {
  id String @id @default(cuid())

  studentId   String
  student     User   @relation("StudentConversations", fields: [studentId], references: [id], onDelete: Cascade)
  recruiterId String
  recruiter   User   @relation("RecruiterConversations", fields: [recruiterId], references: [id], onDelete: Cascade)

  lastMessageAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages     Message[]
  reads        ConversationRead[]
  applications Application[]

  @@unique([studentId, recruiterId])
  @@index([lastMessageAt])
  @@index([studentId])
  @@index([recruiterId])
}

model ConversationRead {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  lastReadAt DateTime @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation("MessageSentBy", fields: [senderId], references: [id], onDelete: Cascade)

  body String @db.Text

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model SavedListing {
  userId    String
  listingId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, listingId])
  @@index([listingId])
}

model Asset {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  kind        AssetKind
  bucket      String
  key         String    @unique
  url         String?
  contentType String?
  sizeBytes   Int?

  createdAt DateTime @default(now())

  @@index([userId, kind])
}

model Payment {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planCode String
  amount   Int
  currency String @default("INR")

  razorpayOrderId   String  @unique
  razorpayPaymentId String? @unique
  razorpaySignature String?

  status PaymentStatus @default(CREATED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type  NotificationType
  title String
  body  String?          @db.Text
  link  String?

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

enum UserRole {
  STUDENT
  EMPLOYER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum ListingType {
  INTERNSHIP
  JOB
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW
  HIRED
  REJECTED
  WITHDRAWN
}

enum CompanyRole {
  OWNER
  MEMBER
}

enum CompanyVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssetKind {
  RESUME
  COMPANY_LOGO
  PROFILE_IMAGE
}

enum NotificationType {
  APPLICATION_RECEIVED
  APPLICATION_STATUS_CHANGED
  APPLICATION_WITHDRAWN
  LISTING_CLOSED
  LISTING_TAKEN_DOWN
  LISTING_RESTORED
  COMPANY_MEMBER_ADDED
  COMPANY_APPROVED
  COMPANY_REJECTED
  SUBSCRIPTION_ACTIVATED
  GENERIC
}

enum PaymentStatus {
  CREATED
  SUCCESS
  FAILED
}
