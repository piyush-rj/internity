generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String  @id @default(cuid())
  name  String?
  email String? @unique
  phone String? @unique
  image String?

  supabaseUserId String? @unique @db.Uuid

  googleId String? @unique

  role          UserRole  @default(STUDENT)
  roleConfirmed Boolean   @default(false)
  isBanned      Boolean   @default(false)
  banReason     String?   @db.Text
  bannedAt      DateTime?

  isPremium      Boolean   @default(false)
  premiumSince   DateTime?
  premiumUntil   DateTime?
  activePlanCode String?

  isOnline   Boolean   @default(false)
  lastSeenAt DateTime?

  deletedAt DateTime?

  activeCompanyId String?
  activeCompany   Company? @relation("UserActiveCompany", fields: [activeCompanyId], references: [id], onDelete: SetNull)

  googleRefreshToken   String?
  googleAccessToken    String?
  googleTokenExpiresAt DateTime?
  googleConnectedEmail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentProfile     StudentProfile?
  employerProfile    EmployerProfile?
  companyMemberships CompanyMember[]
  listingsPosted     Listing[]          @relation("ListingPostedBy")
  listingsTakenDown  Listing[]          @relation("ListingTakenDownBy")
  listingDrafts      ListingDraft[]
  applications       Application[]
  savedListings      SavedListing[]
  assets             Asset[]
  notifications      Notification[]
  payments              Payment[]
  cancellationRequests  CancellationRequest[]
  couponsCreated        Coupon[]              @relation("CouponCreatedBy")
  offersCreated         Offer[]               @relation("OfferCreatedBy")
  freePostingGrantsCreated FreePostingGrant[] @relation("FreePostingGrantCreatedBy")
  couponRedemptions     CouponRedemption[]
  messagesSent          Message[]             @relation("MessageSentBy")
  conversationReads  ConversationRead[]

  studentConversations   Conversation[] @relation("StudentConversations")
  recruiterConversations Conversation[] @relation("RecruiterConversations")

  interviewsHosted    Interview[] @relation("InterviewsHosted")
  interviewsAttending Interview[] @relation("InterviewsAttending")

  companyInvitesSent     CompanyInvitation[] @relation("CompanyInvitesSent")
  companyInvitesAccepted CompanyInvitation[] @relation("CompanyInvitesAccepted")

  reportsFiled    Report[] @relation("ReportReporter")
  reportsAgainst  Report[] @relation("ReportTargetStudent")
  reportsResolved Report[] @relation("ReportResolvedBy")

  @@index([deletedAt])
}

model StudentProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String?
  phone     String?
  city      String?
  dob       DateTime?
  gender    Gender?
  bio       String?   @db.Text

  interestedJobTitles JobTitle[] @default([])

  lastCoverLetter String? @db.Text

  resumeUrl    String?
  linkedinUrl  String?
  portfolioUrl String?

  college String?
  branch  String?

  isVerified Boolean @default(false)

  educations     Education[]
  experiences    WorkExperience[]
  projects       Project[]
  skills         StudentSkill[]
  certifications Certification[]
  languages      Language[]
  resumes        Resume[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
}

model Resume {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)

  fileName  String
  url       String
  sizeBytes Int?

  isDefault  Boolean   @default(false)
  lastUsedAt DateTime?

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([assetId])
}

model Education {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  institute    String
  degree       String
  fieldOfStudy String?
  startYear    Int
  endYear      Int?
  grade        String?
  current      Boolean @default(false)

  @@index([studentId])
}

model WorkExperience {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  company     String
  title       String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  current     Boolean   @default(false)
  description String?   @db.Text

  @@index([studentId])
}

model Project {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  title       String
  link        String?
  description String?   @db.Text
  startDate   DateTime?
  endDate     DateTime?

  @@index([studentId])
}

model Skill {
  id   String @id @default(cuid())
  name String @unique // normalised, lowercase

  students      StudentSkill[]
  listingSkills ListingSkill[]
}

model StudentSkill {
  studentId String
  skillId   String
  level     Int? // 1..5

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  skill   Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([studentId, skillId])
  @@index([skillId])
}

model Certification {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  name          String
  issuer        String?
  issueDate     DateTime?
  credentialUrl String?

  @@index([studentId])
}

model Language {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  name        String
  proficiency Int? // 1..5

  @@index([studentId])
}

model EmployerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName   String
  lastName    String?
  phone       String?
  jobTitle    String?
  linkedinUrl String?
  country     String? @default("India")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  logoUrl      String?
  website      String?
  linkedinUrl  String?
  about        String? @db.Text
  industry     String?
  size         String?
  city         String?
  country      String? @default("India")
  foundingYear Int?

  organizationType OrganizationType?

  verificationStatus CompanyVerificationStatus @default(PENDING)
  rejectionNote      String?                   @db.Text
  submittedAt        DateTime?
  approvedAt         DateTime?

  // Premium plan — owned by the company, visible to all members,
  // cancellable only by FOUNDER_OWNER.
  isPremium      Boolean   @default(false)
  premiumSince   DateTime?
  premiumUntil   DateTime?
  activePlanCode String?

  // Every company gets one free listing before a subscription is required.
  freeListingUsed      Boolean   @default(false)
  freeListingExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members              CompanyMember[]
  invitations          CompanyInvitation[]
  listings             Listing[]
  listingDrafts        ListingDraft[]
  activeFor            User[]                @relation("UserActiveCompany")
  payments             Payment[]
  cancellationRequests CancellationRequest[]
  freePostingGrants    FreePostingGrant[]

  @@index([verificationStatus, submittedAt])
}

// A founder's saved-but-not-posted listing. Holds the post-listing form state
// as a JSON blob (drafts are intentionally partial, so it isn't validated as a
// full listing). Private to the creating user; capped at 10 per user in the
// API. companyId is the company the draft was started under (nullable so the
// draft survives if that company is removed).
model ListingDraft {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  title String @default("Untitled draft")
  data  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
}

model FreePostingGrant {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  grantedPostings Int
  usedPostings    Int @default(0)
  note            String? @db.Text

  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  revokedAt   DateTime?
  revokedById String?

  grantedById String
  grantedBy   User   @relation("FreePostingGrantCreatedBy", fields: [grantedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, isActive])
}

model CompanyInvitation {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  email String
  role  CompanyRole @default(MEMBER)
  customRole String?
  token String      @unique

  invitedById String
  invitedBy   User   @relation("CompanyInvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  acceptedAt DateTime?

  acceptedById String?
  acceptedBy   User?   @relation("CompanyInvitesAccepted", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([email])
}

model CompanyMember {
  companyId String
  userId    String
  role      CompanyRole @default(MEMBER)
  customRole String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@id([companyId, userId])
  @@index([userId])
}

model Listing {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  postedById String
  postedBy   User   @relation("ListingPostedBy", fields: [postedById], references: [id], onDelete: Cascade)

  title       String
  mode        WorkMode
  city        String?
  description String   @db.Text

  jobTitle       JobTitle?
  customJobTitle String?

  responsibilities String[]
  perks            String[]
  preferences      String[]
  skillTagsRaw     String[] // free-text snapshot; normalised m2m below

  screeningQuestions Json @default("[]")

  stipendMin      Int?
  stipendMax      Int?
  currency        String?   @default("INR")
  durationMonths  Int?
  durationWeeks   Int?
  startDate       DateTime?
  startDateLatest DateTime?
  applyBy         DateTime?
  openings        Int?      @default(1)
  partTime        Boolean   @default(false)
  ppo             Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime? // null = live, non-null = closed

  expiresAt DateTime?
  pausedAt  DateTime?

  takenDownAt    DateTime?
  takedownReason String?   @db.Text
  takenDownById  String?
  takenDownBy    User?     @relation("ListingTakenDownBy", fields: [takenDownById], references: [id], onDelete: SetNull)

  skills       ListingSkill[]
  applications Application[]
  savedBy      SavedListing[]
  reports      Report[]       @relation("ReportTargetListing")

  @@index([createdAt])
  @@index([jobTitle])
  @@index([companyId])
  @@index([postedById])
  @@index([city])
  @@index([applyBy])
  @@index([closedAt])
  @@index([takenDownAt])
  @@index([expiresAt])
  @@index([pausedAt])
}

model ListingSkill {
  listingId String
  skillId   String

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([listingId, skillId])
  @@index([skillId])
}

model Application {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  status      ApplicationStatus @default(APPLIED)
  coverLetter String?           @db.Text
  resumeUrl   String? // snapshot of resume at time of apply

  screeningAnswers Json @default("[]")

  appliedAt       DateTime  @default(now())
  statusUpdatedAt DateTime  @default(now())
  seenAt          DateTime?

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  interviews Interview[]

  @@unique([listingId, studentId])
  @@index([studentId, status])
  @@index([listingId, status])
  @@index([conversationId])
}

model Interview {
  id String @id @default(cuid())

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  hostId String
  host   User   @relation("InterviewsHosted", fields: [hostId], references: [id], onDelete: Cascade)

  candidateId String
  candidate   User   @relation("InterviewsAttending", fields: [candidateId], references: [id], onDelete: Cascade)

  title String
  type  InterviewType

  scheduledAt DateTime
  endsAt      DateTime

  timezone String?

  meetingLink String?

  hostPhone String?

  candidatePhone String?

  description String? @db.Text

  status       InterviewStatus @default(SCHEDULED)
  cancelledAt  DateTime?
  cancelReason String?         @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([candidateId, scheduledAt])
  @@index([hostId, scheduledAt])
  @@index([applicationId])
}

model Conversation {
  id String @id @default(cuid())

  studentId   String
  student     User   @relation("StudentConversations", fields: [studentId], references: [id], onDelete: Cascade)
  recruiterId String
  recruiter   User   @relation("RecruiterConversations", fields: [recruiterId], references: [id], onDelete: Cascade)

  // When true, studentId === recruiterId and this thread is shared by all admins.
  isAdminThread Boolean @default(false)

  lastMessageAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages     Message[]
  reads        ConversationRead[]
  applications Application[]

  @@unique([studentId, recruiterId])
  @@index([lastMessageAt])
  @@index([studentId])
  @@index([recruiterId])
}

model ConversationRead {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  lastReadAt DateTime @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation("MessageSentBy", fields: [senderId], references: [id], onDelete: Cascade)

  body String @db.Text

  createdAt DateTime  @default(now())
  // Set the first time the sender edits this message; null = never edited.
  editedAt  DateTime?

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model SavedListing {
  userId    String
  listingId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, listingId])
  @@index([listingId])
}

model Asset {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  kind        AssetKind
  bucket      String
  key         String    @unique
  url         String?
  contentType String?
  sizeBytes   Int?

  createdAt DateTime @default(now())

  resumes Resume[]

  @@index([userId, kind])
}

model Payment {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The company this payment was made for. Nullable for legacy user-level
  // payments; all new payments must carry a companyId.
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  planCode String
  amount   Int
  currency String @default("INR")

  razorpayOrderId   String  @unique
  razorpayPaymentId String? @unique
  razorpaySignature String?

  status PaymentStatus @default(CREATED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cancellationRequest CancellationRequest?

  couponId         String?
  coupon           Coupon?           @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponRedemption CouponRedemption?

  offerId String?
  offer   Offer?  @relation(fields: [offerId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([companyId, createdAt])
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type  NotificationType
  title String
  body  String?          @db.Text
  link  String?

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Report {
  id String @id @default(cuid())

  reporterId String
  reporter   User   @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  targetType ReportTargetType

  targetListingId String?
  targetListing   Listing? @relation("ReportTargetListing", fields: [targetListingId], references: [id], onDelete: Cascade)

  targetStudentId String?
  targetStudent   User?   @relation("ReportTargetStudent", fields: [targetStudentId], references: [id], onDelete: Cascade)

  reason String @db.Text

  status         ReportStatus @default(OPEN)
  resolvedById   String?
  resolvedBy     User?        @relation("ReportResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt     DateTime?
  resolutionNote String?      @db.Text

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([targetListingId])
  @@index([targetStudentId])
  @@index([reporterId])
}

enum UserRole {
  STUDENT
  EMPLOYER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum JobTitle {
  AI
  BACKEND
  WEB
  MOBILE
  QA
  DESIGN
  PRODUCT
  RESEARCHER
  MARKETING
  CONTENT
  VIDEO
  SALES
  SOCIAL
  DATA
  HR
  CUSTOM
}

enum OrganizationType {
  SOLO_FOUNDER
  STARTUP_TEAM
  BOOTSTRAPPED_STARTUP
  PRIVATE_LIMITED
  LLP
  AGENCY
  FREELANCER
  STUDENT_STARTUP
  OTHER
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW
  HIRED
  REJECTED
  WITHDRAWN
}

enum InterviewType {
  VIDEO
  PHONE
}

enum InterviewStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum CompanyRole {
  FOUNDER_OWNER
  CO_FOUNDER
  HR
  MEMBER
  OTHER
  OWNER
}

enum CompanyVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssetKind {
  RESUME
  COMPANY_LOGO
  PROFILE_IMAGE
}

enum NotificationType {
  APPLICATION_RECEIVED
  APPLICATION_STATUS_CHANGED
  APPLICATION_WITHDRAWN
  LISTING_CLOSED
  LISTING_TAKEN_DOWN
  LISTING_RESTORED
  COMPANY_INVITE
  COMPANY_MEMBER_ADDED
  COMPANY_APPROVED
  COMPANY_REJECTED
  SUBSCRIPTION_ACTIVATED
  FREE_POSTING_GRANTED
  FREE_POSTING_REVOKED
  NEW_OFFER
  INTERVIEW_SCHEDULED
  INTERVIEW_CANCELLED
  GENERIC
}

enum PaymentStatus {
  CREATED
  SUCCESS
  FAILED
}

model Coupon {
  id   String @id @default(cuid())
  code String @unique

  // Per-plan discount percentages (0–100). Admin sets a default that
  // pre-fills all three; each can then be individually overridden.
  discountPctPerPost Int
  discountPctMonthly Int
  discountPctYearly  Int

  isActive  Boolean   @default(true)
  revokedAt DateTime?
  revokedById String?

  // Default: 30 days from creation; admin can extend or shorten.
  expiresAt DateTime

  createdById String
  createdBy   User   @relation("CouponCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redemptions CouponRedemption[]
  payments    Payment[]

  @@index([code])
  @@index([isActive, expiresAt])
}

// Promotional offer set by an admin — visible to all users on the pricing
// page without requiring a code. Distinct from coupons (code-based, per-user).
model Offer {
  id          String  @id @default(cuid())
  title       String
  description String? @db.Text

  discountPctPerPost Int
  discountPctMonthly Int
  discountPctYearly  Int

  isActive    Boolean   @default(true)
  revokedAt   DateTime?
  revokedById String?

  // Defaults to 30 days from creation.
  expiresAt DateTime

  createdById String
  createdBy   User   @relation("OfferCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]

  @@index([isActive, expiresAt])
}

model CouponRedemption {
  id String @id @default(cuid())

  couponId String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  paymentId String?  @unique
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  discountPct      Int
  originalAmount   Int
  discountedAmount Int

  createdAt DateTime @default(now())

  @@unique([couponId, userId])
  @@index([userId])
}

enum CancellationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CancellationReason {
  TOO_EXPENSIVE
  LOW_APPLICANT_QUALITY
  ALREADY_HIRED
  FOUND_BETTER_PLATFORM
  TECHNICAL_ISSUES
  OTHER
}

model CancellationRequest {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Company the cancellation is for — populated for all new requests.
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  paymentId String  @unique
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  reason    CancellationReason
  otherText String?            @db.Text

  status CancellationRequestStatus @default(PENDING)

  listingsUsedAtRequest Int

  adminNote    String?   @db.Text
  resolvedById String?
  resolvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([status])
}

enum ReportTargetType {
  LISTING
  STUDENT
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}
