// Internshala clone — Prisma schema (MVP for 2-day build)
// Auth: NextAuth v4 (Google OAuth, JWT strategy — no DB sessions)
// Storage: MinIO (S3-compatible) for resumes and logos

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String  @id @default(cuid())
  name  String?
  email String? @unique
  phone String? @unique
  image String?

  supabaseUserId String? @unique @db.Uuid

  googleId String? @unique

  role          UserRole  @default(STUDENT)
  roleConfirmed Boolean   @default(false)
  isBanned      Boolean   @default(false)
  banReason     String?   @db.Text
  bannedAt      DateTime?

  isPremium    Boolean   @default(false)
  premiumSince DateTime?

  isOnline   Boolean   @default(false)
  lastSeenAt DateTime?

  // Soft-delete. Set when the user hits "delete my account"; everything else
  // stays for audit but the row is excluded from all surfaces.
  deletedAt DateTime?

  // For employers who belong to multiple companies — points to the company
  // currently in focus across the dashboard. Always one of their
  // companyMemberships, or null pre-creation/pre-join.
  activeCompanyId String?
  activeCompany   Company? @relation("UserActiveCompany", fields: [activeCompanyId], references: [id], onDelete: SetNull)

  // Google OAuth (Calendar API) — set when the user connects their Google
  // account to auto-generate Meet links. Tokens stored plaintext for MVP;
  // when going to production, move to app-layer encryption with a separate
  // KMS key. The provider DB (Supabase) already encrypts at rest.
  googleRefreshToken   String?
  googleAccessToken    String?
  googleTokenExpiresAt DateTime?
  googleConnectedEmail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentProfile     StudentProfile?
  employerProfile    EmployerProfile?
  companyMemberships CompanyMember[]
  listingsPosted     Listing[]          @relation("ListingPostedBy")
  listingsTakenDown  Listing[]          @relation("ListingTakenDownBy")
  applications       Application[]
  savedListings      SavedListing[]
  assets             Asset[]
  notifications      Notification[]
  payments           Payment[]
  messagesSent       Message[]          @relation("MessageSentBy")
  conversationReads  ConversationRead[]

  studentConversations   Conversation[] @relation("StudentConversations")
  recruiterConversations Conversation[] @relation("RecruiterConversations")

  interviewsHosted    Interview[] @relation("InterviewsHosted")
  interviewsAttending Interview[] @relation("InterviewsAttending")

  companyInvitesSent     CompanyInvitation[] @relation("CompanyInvitesSent")
  companyInvitesAccepted CompanyInvitation[] @relation("CompanyInvitesAccepted")

  reportsFiled    Report[] @relation("ReportReporter")
  reportsAgainst  Report[] @relation("ReportTargetStudent")
  reportsResolved Report[] @relation("ReportResolvedBy")

  @@index([deletedAt])
}

model StudentProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String?
  phone     String?
  city      String?
  dob       DateTime?
  gender    Gender?
  bio       String?   @db.Text

  // Roles the student is looking for. Drives ranking on the listings feed
  // and prefills the post-application "roles you matched" UI. Stored as a
  // typed array so we can join cheaply against Listing.jobTitle.
  interestedJobTitles JobTitle[] @default([])

  // Carbon-copy of the last cover letter the student submitted on Apply.
  // Used to one-click prefill subsequent applications. Cleared if they ever
  // delete their account (the account-delete path nulls profile PII).
  lastCoverLetter String? @db.Text

  // Default/primary resume URL — mirrors the Resume row flagged isDefault.
  // Kept denormalised because most reads (search cards, public profile)
  // just need one URL without joining a child table.
  resumeUrl    String?
  linkedinUrl  String?
  portfolioUrl String?

  // Top-level shortcuts surfaced on cards + filters. Education[] still
  // holds the full history; these are the founder-facing summary fields.
  college String?
  branch  String?

  // Admin-toggled verification badge. Display-only — no functional gating.
  isVerified Boolean @default(false)

  educations     Education[]
  experiences    WorkExperience[]
  projects       Project[]
  skills         StudentSkill[]
  certifications Certification[]
  languages      Language[]
  resumes        Resume[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
}

// Student-managed resume file. A student can keep up to 4 (enforced in the
// controller) and exactly one is flagged isDefault — that's the one auto-
// selected on apply. Application.resumeUrl snapshots whichever was chosen
// at apply time so deletes here don't break past applications.
model Resume {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)

  fileName  String
  url       String
  sizeBytes Int?

  isDefault  Boolean   @default(false)
  lastUsedAt DateTime?

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([assetId])
}

model Education {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  institute    String
  degree       String
  fieldOfStudy String?
  startYear    Int
  endYear      Int?
  grade        String?
  current      Boolean @default(false)

  @@index([studentId])
}

model WorkExperience {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  company     String
  title       String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  current     Boolean   @default(false)
  description String?   @db.Text

  @@index([studentId])
}

model Project {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  title       String
  link        String?
  description String?   @db.Text
  startDate   DateTime?
  endDate     DateTime?

  @@index([studentId])
}

model Skill {
  id   String @id @default(cuid())
  name String @unique // normalised, lowercase

  students      StudentSkill[]
  listingSkills ListingSkill[]
}

model StudentSkill {
  studentId String
  skillId   String
  level     Int? // 1..5

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  skill   Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([studentId, skillId])
  @@index([skillId])
}

model Certification {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  name          String
  issuer        String?
  issueDate     DateTime?
  credentialUrl String?

  @@index([studentId])
}

model Language {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  name        String
  proficiency Int? // 1..5

  @@index([studentId])
}

model EmployerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName   String
  lastName    String?
  phone       String?
  jobTitle    String?
  linkedinUrl String?
  country     String? @default("India")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  logoUrl      String?
  website      String?
  linkedinUrl  String?
  about        String? @db.Text
  industry     String?
  size         String?
  city         String?
  country      String? @default("India")
  foundingYear Int?

  organizationType OrganizationType?

  // Admin verification gate. Listings can still be posted while PENDING —
  // they just don't display the "Verified" badge until APPROVED. REJECTED
  // carries a rejectionNote and can be edited+resubmitted (which flips
  // status back to PENDING).
  verificationStatus CompanyVerificationStatus @default(PENDING)
  rejectionNote      String?                   @db.Text
  submittedAt        DateTime?
  approvedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     CompanyMember[]
  invitations CompanyInvitation[]
  listings    Listing[]
  activeFor   User[]              @relation("UserActiveCompany")

  @@index([verificationStatus, submittedAt])
}

// Pending invite for a non-member to join a company by email. Created by an
// existing OWNER; the invitee clicks the share link (which contains the
// token) and confirms while signed in. Single open invite per (company,
// email) is enforced in the controller.
model CompanyInvitation {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  email String
  role  CompanyRole @default(MEMBER)
  token String      @unique

  invitedById String
  invitedBy   User   @relation("CompanyInvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  acceptedAt DateTime?

  acceptedById String?
  acceptedBy   User?   @relation("CompanyInvitesAccepted", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([email])
}

model CompanyMember {
  companyId String
  userId    String
  role      CompanyRole @default(MEMBER)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@id([companyId, userId])
  @@index([userId])
}

model Listing {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  postedById String
  postedBy   User   @relation("ListingPostedBy", fields: [postedById], references: [id], onDelete: Cascade)

  title       String
  mode        WorkMode
  city        String?
  description String   @db.Text

  // The picked job-title bucket from the predefined list, or CUSTOM when the
  // employer typed their own. customJobTitle holds the free-text only when
  // jobTitle = CUSTOM; for predefined picks it's null and the display title
  // is the friendly label for the enum value.
  jobTitle       JobTitle?
  customJobTitle String?

  responsibilities String[]
  perks            String[]
  preferences      String[]
  skillTagsRaw     String[] // free-text snapshot; normalised m2m below

  // Optional founder-defined screening questions. Stored as JSON because
  // each entry is now a structured object: { q, type, options?, ideal? }
  // where type is one of SHORT, YES_NO, MULTIPLE_CHOICE, NUMBERS, SCALE_1_5.
  // Capped at 3 per the "no long forms" product principle. When non-empty,
  // students must submit answers (same count, same order) at apply time.
  screeningQuestions Json @default("[]")

  stipendMin      Int?
  stipendMax      Int?
  currency        String?   @default("INR")
  // Duration is split into a months component and a weeks component so the
  // UI can render short engagements honestly (e.g. "2 months 3 weeks").
  // Either or both may be set; ranking treats `durationMonths * 4 +
  // durationWeeks` as the equivalent total weeks.
  durationMonths  Int?
  durationWeeks   Int?
  // Start date is either a single target ("Immediately" = both null; the
  // listing implies a within-30-days start) or a range. When startDateLatest
  // is set, students see "Start between X and Y" — otherwise just startDate.
  startDate       DateTime?
  startDateLatest DateTime?
  applyBy         DateTime?
  openings        Int?      @default(1)
  partTime        Boolean   @default(false)
  // Pre-placement offer flag. Asked as a separate yes/no on the form so it
  // surfaces prominently on the listing card; not stored as a perk.
  ppo             Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime? // null = live, non-null = closed

  // Lifecycle. expiresAt is set on creation to createdAt + 30 days; once it
  // passes the listing is hidden from public surfaces until the founder
  // renews. pausedAt = "Not Hiring" — also hides from browse but keeps
  // existing applicants visible to the founder.
  expiresAt DateTime?
  pausedAt  DateTime?

  // Admin moderation (soft-removal). When takenDownAt is set the listing
  // becomes hidden from public browse + the founder's own listings show it
  // as "Removed by admin" with the reason. An admin can restore it.
  takenDownAt    DateTime?
  takedownReason String?   @db.Text
  takenDownById  String?
  takenDownBy    User?     @relation("ListingTakenDownBy", fields: [takenDownById], references: [id], onDelete: SetNull)

  skills       ListingSkill[]
  applications Application[]
  savedBy      SavedListing[]
  reports      Report[]       @relation("ReportTargetListing")

  @@index([createdAt])
  @@index([jobTitle])
  @@index([companyId])
  @@index([postedById])
  @@index([city])
  @@index([applyBy])
  @@index([closedAt])
  @@index([takenDownAt])
  @@index([expiresAt])
  @@index([pausedAt])
}

model ListingSkill {
  listingId String
  skillId   String

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([listingId, skillId])
  @@index([skillId])
}

model Application {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  status      ApplicationStatus @default(APPLIED)
  coverLetter String?           @db.Text
  resumeUrl   String? // snapshot of resume at time of apply

  // Parallel to Listing.screeningQuestions at apply time. Same length and
  // order. Each entry is { value: string | number } so we can round-trip
  // the per-type response shape (text for SHORT, "yes"/"no" for YES_NO,
  // an option label for MULTIPLE_CHOICE, a number for NUMBERS/SCALE_1_5).
  // Empty array when the listing had no questions.
  screeningAnswers Json @default("[]")

  appliedAt       DateTime  @default(now())
  statusUpdatedAt DateTime  @default(now())
  // Set the first time a founder opens the applicants page for this listing.
  // Orthogonal to `status` — a founder may see an applicant and then move
  // them through SHORTLISTED / HIRED / etc., and the student still benefits
  // from knowing the first "seen" moment.
  seenAt          DateTime?

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  interviews Interview[]

  @@unique([listingId, studentId])
  @@index([studentId, status])
  @@index([listingId, status])
  @@index([conversationId])
}

// One scheduled meeting (video call or phone call) between a founder and
// an applicant, attached to a specific Application. Multiple interviews per
// application are allowed (rescheduling, multiple rounds) — the app-layer
// rule is "at most one SCHEDULED at a time", not a DB constraint.
model Interview {
  id String @id @default(cuid())

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  hostId String
  host   User   @relation("InterviewsHosted", fields: [hostId], references: [id], onDelete: Cascade)

  candidateId String
  candidate   User   @relation("InterviewsAttending", fields: [candidateId], references: [id], onDelete: Cascade)

  title String
  type  InterviewType

  scheduledAt DateTime
  endsAt      DateTime

  // IANA timezone of the host at schedule time (e.g. "Asia/Kolkata"). UI
  // displays scheduledAt in this TZ alongside the viewer's local TZ.
  timezone String?

  // VIDEO: founder pastes Meet/Zoom/Teams URL here. PHONE: null.
  meetingLink String?

  // Founder's contact number shared with the candidate. Optional for video,
  // required at the app layer for phone.
  hostPhone String?

  // Snapshot of the student's phone at schedule time — survives later
  // profile edits so the founder doesn't lose the number they expected.
  candidatePhone String?

  description String? @db.Text

  status       InterviewStatus @default(SCHEDULED)
  cancelledAt  DateTime?
  cancelReason String?         @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([candidateId, scheduledAt])
  @@index([hostId, scheduledAt])
  @@index([applicationId])
}

model Conversation {
  id String @id @default(cuid())

  studentId   String
  student     User   @relation("StudentConversations", fields: [studentId], references: [id], onDelete: Cascade)
  recruiterId String
  recruiter   User   @relation("RecruiterConversations", fields: [recruiterId], references: [id], onDelete: Cascade)

  lastMessageAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages     Message[]
  reads        ConversationRead[]
  applications Application[]

  @@unique([studentId, recruiterId])
  @@index([lastMessageAt])
  @@index([studentId])
  @@index([recruiterId])
}

model ConversationRead {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  lastReadAt DateTime @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation("MessageSentBy", fields: [senderId], references: [id], onDelete: Cascade)

  body String @db.Text

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model SavedListing {
  userId    String
  listingId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, listingId])
  @@index([listingId])
}

model Asset {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  kind        AssetKind
  bucket      String
  key         String    @unique
  url         String?
  contentType String?
  sizeBytes   Int?

  createdAt DateTime @default(now())

  resumes Resume[]

  @@index([userId, kind])
}

model Payment {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planCode String
  amount   Int
  currency String @default("INR")

  razorpayOrderId   String  @unique
  razorpayPaymentId String? @unique
  razorpaySignature String?

  status PaymentStatus @default(CREATED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type  NotificationType
  title String
  body  String?          @db.Text
  link  String?

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// Abuse report filed against either a Listing (by a student) or a Student
// (by an employer). Surfaces in the admin queue; admin reviews and decides.
// No automatic takedown — admin must act.
model Report {
  id String @id @default(cuid())

  reporterId String
  reporter   User   @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  targetType ReportTargetType

  targetListingId String?
  targetListing   Listing? @relation("ReportTargetListing", fields: [targetListingId], references: [id], onDelete: Cascade)

  targetStudentId String?
  targetStudent   User?   @relation("ReportTargetStudent", fields: [targetStudentId], references: [id], onDelete: Cascade)

  reason String @db.Text

  status         ReportStatus @default(OPEN)
  resolvedById   String?
  resolvedBy     User?        @relation("ReportResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt     DateTime?
  resolutionNote String?      @db.Text

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([targetListingId])
  @@index([targetStudentId])
  @@index([reporterId])
}

enum UserRole {
  STUDENT
  EMPLOYER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

// Predefined job-title buckets shown in the post-listing dropdown. Each
// value maps 1:1 to a friendly display label (resolved in the web app's
// job-title catalog). CUSTOM means the employer typed their own title;
// in that case Listing.customJobTitle holds the text.
enum JobTitle {
  AI
  BACKEND
  WEB
  MOBILE
  QA
  DESIGN
  PRODUCT
  MARKETING
  CONTENT
  SALES
  DATA
  HR
  CUSTOM
}

// Company self-description, asked once at company-creation time. Used on
// the public company page and surfaces in admin verification review.
enum OrganizationType {
  SOLO_FOUNDER
  STARTUP_TEAM
  BOOTSTRAPPED_STARTUP
  PRIVATE_LIMITED
  LLP
  AGENCY
  FREELANCER
  STUDENT_STARTUP
  OTHER
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW
  HIRED
  REJECTED
  WITHDRAWN
}

enum InterviewType {
  VIDEO
  PHONE
}

enum InterviewStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

// Role within a company.
//   FOUNDER_OWNER, CO_FOUNDER → full admin (post listings, edit company, manage team).
//   HR                        → manage applicants + interviews; cannot edit listings or team.
//   MEMBER                    → post listings only; no team / company admin.
// Legacy `OWNER` is mapped to FOUNDER_OWNER by a data migration; kept here so
// existing rows in any not-yet-migrated environment still parse.
enum CompanyRole {
  FOUNDER_OWNER
  CO_FOUNDER
  HR
  MEMBER
  OWNER
}

enum CompanyVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssetKind {
  RESUME
  COMPANY_LOGO
  PROFILE_IMAGE
}

enum NotificationType {
  APPLICATION_RECEIVED
  APPLICATION_STATUS_CHANGED
  APPLICATION_WITHDRAWN
  LISTING_CLOSED
  LISTING_TAKEN_DOWN
  LISTING_RESTORED
  COMPANY_INVITE
  COMPANY_MEMBER_ADDED
  COMPANY_APPROVED
  COMPANY_REJECTED
  SUBSCRIPTION_ACTIVATED
  INTERVIEW_SCHEDULED
  INTERVIEW_CANCELLED
  GENERIC
}

enum PaymentStatus {
  CREATED
  SUCCESS
  FAILED
}

enum ReportTargetType {
  LISTING
  STUDENT
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}
